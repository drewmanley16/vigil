# ─── Agent ───────────────────────────────────────────────────────────────────
RPC_URL=https://sepolia.base.org
CONTRACT_ADDRESS=0x...                 # GuardianWallet deployed address
AGENT_PRIVATE_KEY=0x...               # Agent EOA private key (only setRiskScore perms)
VENICE_API_KEY=...                    # Venice AI API key
TELEGRAM_BOT_TOKEN=...               # From @BotFather
TELEGRAM_CHAT_ID=...                 # Guardian's chat ID (from /getUpdates)
SEEN_ADDRESSES_PATH=./data/seen_addresses.json
POLL_INTERVAL_MS=15000

# ─── ERC-8004 ─────────────────────────────────────────────────────────────────
ERC8004_REGISTRY_ADDRESS=0x...        # ERC-8004 Identity Registry on Base Sepolia/Mainnet
AGENT_URI=https://raw.githubusercontent.com/drewmanley16/vigil/main/docs/agent-registration.json
AGENT_ID=0                            # Set after first registration to skip re-registration

# ─── Contracts (deploy) ──────────────────────────────────────────────────────
OWNER_ADDRESS=0x...                   # Elderly person's wallet address
THRESHOLD_ETH=1                       # Safety threshold in ETH
PRIVATE_KEY=0x...                     # Deployer private key (can be same as owner)
BASESCAN_API_KEY=...                  # For contract verification

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_CONTRACT_ADDRESS=0x...    # Same as CONTRACT_ADDRESS above

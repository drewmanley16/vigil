{
  "schemaVersion": "1.0",
  "name": "Vigil",
  "version": "1.0.0",
  "description": "Elder financial fraud prevention agent. Monitors a GuardianWallet smart contract on Base for suspicious outbound transactions. Every transaction is analyzed by Venice AI (private inference, zero data retention) using 6 heuristic signals. Large transactions are escrowed until a family guardian co-signs. Guardians receive Telegram alerts with risk scores, Venice's plain-English reasoning, and one-tap approve/cancel buttons. Risk scores and feedback hashes are written on-chain for full auditability. Also performs session-level behavioral pattern analysis and generates on-demand Venice guardian reports.",
  "author": {
    "name": "Drew Manley",
    "contact": { "telegram": "@drewmanley" }
  },
  "repository": "https://github.com/drewmanley16/vigil",
  "license": "MIT",
  "network": "base",
  "chains": [8453, 84532],
  "contract": "0x38d5d97C29440C7a50cCc489928bC36392fb4981",
  "agentWallet": "0x5DacE6e950F3e8c18684395B518EdE2465a895b0",
  "erc8004": {
    "agentId": 2279,
    "registry": "eip155:84532:0x8004A818BFB912233c491871b3d84c89A494BD9e",
    "agentUri": "https://raw.githubusercontent.com/drewmanley16/vigil/main/docs/agent-registration.json"
  },
  "endpoints": {
    "frontend": "https://vigil-guardian.vercel.app",
    "dashboard": "https://vigil-guardian.vercel.app/dashboard",
    "health": "https://vigil-agent-production.up.railway.app/health",
    "stats": "https://vigil-agent-production.up.railway.app/stats",
    "agentLog": "https://vigil-agent-production.up.railway.app/agent-log",
    "guardianReport": "https://vigil-agent-production.up.railway.app/guardian-report"
  },
  "x402": {
    "enabled": true,
    "endpoint": "/guardian-report",
    "scheme": "exact",
    "network": "base-sepolia",
    "asset": "0x0000000000000000000000000000000000000000",
    "maxAmountRequired": "100",
    "payTo": "0x5DacE6e950F3e8c18684395B518EdE2465a895b0",
    "description": "Venice AI guardian report — private inference, zero data retention"
  },
  "capabilities": [
    "transaction-monitoring",
    "risk-analysis",
    "guardian-alerting",
    "on-chain-attestation",
    "erc8004-feedback-receipts",
    "behavioral-pattern-analysis",
    "guardian-report-generation",
    "x402-payment-gated-api"
  ],
  "signals": [
    { "id": "FIRST_TIME_RECIPIENT", "weight": 0.4, "description": "Recipient has never received funds from this wallet" },
    { "id": "ABOVE_THRESHOLD", "weight": 0.3, "description": "Transaction value exceeds the configured escrow threshold" },
    { "id": "CONTRACT_INTERACTION", "weight": 0.3, "description": "Recipient is a smart contract rather than an EOA" },
    { "id": "RAPID_SUCCESSION", "weight": 0.2, "description": "Multiple transactions within a short time window" },
    { "id": "UNUSUAL_HOUR", "weight": 0.1, "description": "Transaction initiated during unusual hours (23:00–06:00)" },
    { "id": "ROUND_NUMBER_AMOUNT", "weight": 0.2, "description": "Transaction is a suspiciously round ETH amount (e.g. 0.1, 0.5, 1.0)" }
  ],
  "veniceIntegration": {
    "model": "llama-3.3-70b",
    "privateInference": true,
    "dataRetention": "none",
    "webSearch": false,
    "useCases": [
      "per-transaction-risk-analysis",
      "session-behavioral-pattern-analysis",
      "guardian-weekly-report-synthesis"
    ]
  },
  "trustModel": {
    "canInitiateTransfers": false,
    "canHoldFunds": false,
    "scopedTo": ["setRiskScore()"],
    "privateInference": true,
    "inferenceProvider": "Venice AI",
    "dataRetention": "none",
    "feedbackSigner": "0xE921b57939Ce3AdAF90b085Af053aBeEaC88ad5e"
  },
  "runtime": {
    "platform": "Railway",
    "language": "TypeScript",
    "framework": "Node.js",
    "pollingIntervalMs": 15000,
    "persistence": ["seen_addresses.json", "processed_hashes.json"]
  }
}

{
  "schemaVersion": "erc8004-v1",
  "name": "Vigil",
  "description": "Elder financial fraud prevention agent. Monitors a GuardianWallet smart contract on Base, analyzes transactions using Venice API (private, no-retention inference), and alerts designated guardians via Telegram. Large transactions are escrowed until a guardian co-signs.",
  "version": "1.0.0",
  "author": "Drew Manley",
  "repository": "https://github.com/drewmanley16/vigil",
  "capabilities": [
    "transaction-monitoring",
    "risk-analysis",
    "guardian-alerting",
    "on-chain-attestation"
  ],
  "trustModel": {
    "canInitiateTransfers": false,
    "canHoldFunds": false,
    "scopedTo": ["setRiskScore()"],
    "privateInference": true,
    "dataRetention": "none"
  },
  "inferenceProvider": {
    "name": "Venice AI",
    "model": "llama-3.3-70b",
    "dataRetention": false,
    "endpoint": "https://api.venice.ai/api/v1/chat/completions"
  },
  "network": "base",
  "chains": [8453, 84532],
  "agentWallet": "0x5DacE6e950F3e8c18684395B518EdE2465a895b0",
  "contact": {
    "telegram": "@drewmanley16"
  }
}
